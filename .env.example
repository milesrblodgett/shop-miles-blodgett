# Stripe secret key (starts with sk_test_ for testing, sk_live_ for production)
STRIPE_SECRET_KEY=sk_test_YOUR_KEY_HERE

# Stripe webhook secret (starts with whsec_)
STRIPE_WEBHOOK_SECRET=whsec_YOUR_SECRET_HERE

# Resend API key for sending order notification emails
# Sign up free at https://resend.com
RESEND_API_KEY=re_YOUR_KEY_HERE
